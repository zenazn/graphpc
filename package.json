{
  "name": "graphpc",
  "version": "0.9.4",
  "description": "Type-safe graph API for TypeScript. Like GraphQL, without the query language.",
  "license": "MIT",
  "author": "Carl Jackson",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zenazn/graphpc.git"
  },
  "homepage": "https://github.com/zenazn/graphpc#readme",
  "bugs": {
    "url": "https://github.com/zenazn/graphpc/issues"
  },
  "keywords": [
    "graphpc",
    "graph",
    "rpc",
    "api",
    "typescript"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client-entry.d.ts",
      "import": "./dist/client-entry.js"
    },
    "./eslint": {
      "types": "./dist/eslint/index.d.ts",
      "import": "./dist/eslint/index.js"
    }
  },
  "files": [
    "dist",
    "docs"
  ],
  "scripts": {
    "clean": "bun -e 'import {rmSync} from \"node:fs\"; rmSync(\"dist\",{recursive:true,force:true})'",
    "build": "bun run clean && bun run build:entries && bun run build:eslint && bun run build:types",
    "build:entries": "bun build src/index.ts src/client-entry.ts --outdir dist --target node --format esm --splitting --external @typescript-eslint/utils --external devalue --external @standard-schema/spec",
    "build:eslint": "bun build src/eslint/index.ts --outdir dist/eslint --target node --format esm --external @typescript-eslint/utils",
    "build:types": "tsc -p tsconfig.build.json && bun scripts/fix-dts-extensions.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepublishOnly": "bun run build && bun run typecheck && bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@typescript-eslint/rule-tester": "^8.57.1",
    "@typescript-eslint/utils": "^8.57.1",
    "prettier": "^3.8.1",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@typescript-eslint/utils": "^8",
    "typescript": "^5.9.3"
  },
  "peerDependenciesMeta": {
    "@typescript-eslint/utils": {
      "optional": true
    }
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0",
    "devalue": "^5.6.4"
  }
}
